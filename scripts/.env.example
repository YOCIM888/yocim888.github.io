# 开发环境配置示例
# 复制此文件为 .env 并修改相应配置

# 构建配置
NODE_ENV=development
BUILD_MODE=development

# 服务器配置
PORT=8080
HOST=localhost

# 开发工具配置
ESLINT_NO_DEV_ERRORS=true
PRETTIER_WRITE=true

# 调试配置
DEBUG=yocim:*
LOG_LEVEL=debug

# 构建优化配置
MINIFY_HTML=false
OPTIMIZE_CSS=false
COMPRESS_ASSETS=false

# 搜索索引配置
SEARCH_INDEX_ENABLED=true
SEARCH_INDEX_PATH=./data/search-index.json

# 数据源配置
CSV_ENCODING=utf-8
CSV_DELIMITER=,

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600