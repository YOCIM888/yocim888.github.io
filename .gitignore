# ==============================================
# 1. 系统通用文件（所有系统都会生成的垃圾）
# ==============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
*.swp
*.swo


# ==============================================
# 2. 编辑器与IDE（VS Code 专属，你用的就是这个）
# ==============================================
.vscode/*
# 保留团队共享的编辑器配置（可选，不需要就注释掉）
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# 其他编辑器（备用）
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.c9/
*.sublime-project
*.sublime-workspace


# ==============================================
# 3. 前端开发（Node.js 全生态）
# ==============================================
# 依赖文件夹（核心！绝对不能传）
node_modules/
.pnp/
.pnp.js

# 包管理器缓存
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/
bun.lockb

# 构建产物（打包后的文件，不需要传源码库）
dist/
build/
out/
.next/
.nuxt/
.output/
.astro/
.vuepress/dist/
public/build/

# 测试与覆盖率
coverage/
.nyc_output/

# 前端框架临时文件
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.tsbuildinfo


# ==============================================
# 4. Python 开发（你用的虚拟环境+所有常见垃圾）
# ==============================================
# 虚拟环境（核心！绝对不能传）
.venv/
venv/
ENV/
env/
.env/
.ENV/

# Python 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 打包与分发
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
sdist/
wheelhouse/
*.whl

# 测试与工具
.pytest_cache/
.tox/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter Notebook
.ipynb_checkpoints/


# ==============================================
# 5. 敏感文件与环境变量（绝对不能传！！！）
# ==============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# 密钥与证书
*.key
*.pem
*.cert
*.p12
secret*
password*


# ==============================================
# 6. 日志与临时文件
# ==============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp
*.bak
*.swp


# ==============================================
# 7. 你可能用到的其他项目类型（按需保留）
# ==============================================
# Arduino
*.hex
*.bin
build-*

# Git 本身
*.patch
*.diff

# 压缩包
*.zip
*.tar.gz
*.rar
*.7z